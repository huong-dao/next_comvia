### 8.1 Unit Tests for Error Handling
```typescript
// src/tests/errorHandling.test.ts
describe('Error Handling', () => {
  describe('validateTopupAmount', () => {
    test('should return null for valid amount', () => {
      const result = validateTopupAmount(50000);
      expect(result).toBeNull();
    });

    test('should return error for invalid amount', () => {
      const result = validateTopupAmount(-1000);
      expect(result).toBeInstanceOf(TopupError);
      expect(result?.errorCode).toBe(TopupErrorCode.INVALID_AMOUNT);
    });

    test('should return error for amount too small', () => {
      const result = validateTopupAmount(5000);
      expect(result?.errorCode).toBe(TopupErrorCode.AMOUNT_TOO_SMALL);
    });
  });

  describe('handleAPIError', () => {
    test('should handle network error', () => {
      const error = { message: 'Network Error' };
      const result = handleAPIError(error);
      expect(result).toBeInstanceOf(NetworkError);
    });

    test('should handle 400 validation error', () => {
      const error = {
        response: {
          status: 400,
          data: { errorCode: TopupErrorCode.INVALID_AMOUNT, message: 'Invalid amount' }
        }
      };
      const result = handleAPIError(error);
      expect(result).toBeInstanceOf(TopupError);
      expect(result?.errorCode).toBe(TopupErrorCode.INVALID_AMOUNT);
    });
  });
});
