# Frontend Error Handling Guide

## Overview
Hướng dẫn chi tiết về xử lý lỗi trong frontend Pay2S integration, bao gồm các kịch bản lỗi và cách xử lý.

## 1. Error Types and Categories

### 1.1 Network Errors
- Connection timeout
- Server unavailable
- DNS resolution failure
- CORS issues

### 1.2 API Errors
- Validation errors (400)
- Authentication errors (401)
- Authorization errors (403)
- Not found errors (404)
- Rate limiting (429)
- Server errors (500+)

### 1.3 Business Logic Errors
- Invalid amount
- Insufficient balance
- Expired QR code
- Payment timeout
- Duplicate requests

### 1.4 Pay2S Specific Errors
- Invalid bank account
- Pay2S API errors
- Signature verification failures
- Payment gateway timeouts

## 2. Error Handling Architecture

### 2.1 Error Class Hierarchy
```typescript
// Base error class
abstract class BaseError extends Error {
  abstract readonly code: string;
  abstract readonly type: string;
  abstract readonly userMessage: string;
  
  constructor(message: string, public readonly details?: any) {
    super(message);
    this.name = this.constructor.name;
  }
}

// Network errors
class NetworkError extends BaseError {
  readonly code = 'NETWORK_ERROR';
  readonly type = 'network';
  readonly userMessage = 'Lỗi kết nối mạng. Vui lòng kiểm tra kết nối và thử lại.';
}

// API errors
class APIError extends BaseError {
  readonly code = 'API_ERROR';
  readonly type = 'api';
  readonly userMessage = 'Lỗi hệ thống. Vui lòng thử lại sau.';
}

// Business logic errors
class BusinessError extends BaseError {
  readonly code = 'BUSINESS_ERROR';
  readonly type = 'business';
  readonly userMessage = 'Thao tác không hợp lệ. Vui lòng kiểm tra lại thông tin.';
}

// Pay2S errors
class Pay2SError extends BaseError {
  readonly code = 'PAY2S_ERROR';
  readonly type = 'payment';
  readonly userMessage = 'Lỗi cổng thanh toán. Vui lòng thử lại hoặc chọn phương thức khác.';
}
```

### 2.2 Specific Error Types
```typescript
// Topup specific errors
export enum TopupErrorCode {
  INVALID_AMOUNT = 'INVALID_AMOUNT',
  AMOUNT_TOO_SMALL = 'AMOUNT_TOO_SMALL',
  AMOUNT_TOO_LARGE = 'AMOUNT_TOO_LARGE',
  NO_MONEY_ACCOUNT = 'NO_MONEY_ACCOUNT',
  INVALID_MONEY_ACCOUNT = 'INVALID_MONEY_ACCOUNT',
  PAY2S_API_ERROR = 'PAY2S_API_ERROR',
  PAY2S_TIMEOUT = 'PAY2S_TIMEOUT',
  QR_GENERATION_FAILED = 'QR_GENERATION_FAILED',
  PAYMENT_EXPIRED = 'PAYMENT_EXPIRED',
  PAYMENT_FAILED = 'PAYMENT_FAILED',
  INSUFFICIENT_BALANCE = 'INSUFFICIENT_BALANCE',
  DUPLICATE_REQUEST = 'DUPLICATE_REQUEST',
  INVALID_BILLING_INFO = 'INVALID_BILLING_INFO'
}

export class TopupError extends BusinessError {
  constructor(
    public readonly errorCode: TopupErrorCode,
    message: string,
    details?: any
  ) {
    super(message, details);
    this.code = errorCode;
  }

  get userMessage(): string {
    switch (this.errorCode) {
      case TopupErrorCode.INVALID_AMOUNT:
        return 'Số tiền không hợp lệ. Vui lòng nhập số tiền hợp lệ.';
      case TopupErrorCode.AMOUNT_TOO_SMALL:
        return 'Số tiền tối thiểu là 10,000 VNĐ.';
      case TopupErrorCode.AMOUNT_TOO_LARGE:
        return 'Số tiền vượt quá giới hạn cho phép.';
      case TopupErrorCode.NO_MONEY_ACCOUNT:
        return 'Không tìm thấy tài khoản ngân hàng. Vui lòng liên hệ quản trị viên.';
      case TopupErrorCode.INVALID_MONEY_ACCOUNT:
        return 'Tài khoản ngân hàng không hợp lệ. Vui lòng chọn tài khoản khác.';
      case TopupErrorCode.PAY2S_API_ERROR:
        return 'Lỗi từ cổng thanh toán. Vui lòng thử lại sau.';
      case TopupErrorCode.PAY2S_TIMEOUT:
        return 'Cổng thanh toán phản hồi chậm. Vui lòng thử lại.';
      case TopupErrorCode.QR_GENERATION_FAILED:
        return 'Không tạo được mã QR. Vui lòng thử lại.';
      case TopupErrorCode.PAYMENT_EXPIRED:
        return 'Mã QR đã hết hạn. Vui lòng tạo lại yêu cầu thanh toán.';
      case TopupErrorCode.PAYMENT_FAILED:
        return 'Thanh toán thất bại. Vui lòng thử lại.';
      case TopupErrorCode.INSUFFICIENT_BALANCE:
        return 'Số dư không đủ. Vui lòng nạp thêm tiền.';
      case TopupErrorCode.DUPLICATE_REQUEST:
        return 'Yêu cầu trùng lặp. Vui lòng đợi xử lý yêu cầu hiện tại.';
      case TopupErrorCode.INVALID_BILLING_INFO:
        return 'Thông tin xuất hóa đơn không hợp lệ. Vui lòng cập nhật thông tin.';
      default:
        return 'Đã xảy ra lỗi. Vui lòng thử lại.';
    }
  }
}
```

## 3. Error Handling Implementation

### 3.1 API Error Handler
```typescript
// src/utils/apiErrorHandler.ts
export const handleAPIError = (error: any): BaseError => {
  if (!error.response) {
    // Network error
    if (error.code === 'ECONNABORTED') {
      return new NetworkError('Request timeout');
    }
    return new NetworkError('Network connection failed');
  }

  const { status, data } = error.response;

  switch (status) {
    case 400:
      return handleValidationError(data);
    case 401:
      return new APIError('Unauthorized - Please login again');
    case 403:
      return new APIError('Forbidden - Insufficient permissions');
    case 404:
      return new APIError('Resource not found');
    case 409:
      return new BusinessError('Resource already exists');
    case 422:
      return handleValidationError(data);
    case 429:
      return new APIError('Too many requests - Please try again later');
    case 500:
    case 502:
    case 503:
    case 504:
      return new APIError('Server error - Please try again later');
    default:
      return new APIError(`HTTP ${status} - Unknown error`);
  }
};

const handleValidationError = (data: any): BaseError => {
  if (data.errorCode && Object.values(TopupErrorCode).includes(data.errorCode)) {
    return new TopupError(data.errorCode, data.message, data.details);
  }
  
  if (data.message) {
    return new BusinessError(data.message);
  }
  
  return new BusinessError('Validation failed');
};
```

### 3.2 Component Error Handling
```typescript
// src/components/TopupForm.tsx
import { useState, useCallback } from 'react';
import { handleAPIError, TopupError } from '../utils/errorHandler';

const TopupForm: React.FC = () => {
  const [error, setError] = useState<BaseError | null>(null);
  const [loading, setLoading] = useState(false);

  const handleCreateTopup = useCallback(async (amount: number, accountId: string) => {
    setError(null);
    setLoading(true);

    try {
      const result = await createTopupWithPay2S({ amountExclVat: amount, moneyAccountId: accountId });
      // Handle success
    } catch (err) {
      const error = handleAPIError(err);
      setError(error);
      
      // Log error for debugging
      console.error('Topup creation failed:', error);
      
      // Track error for analytics
      trackError('topup_creation_failed', error.code, error.details);
    } finally {
      setLoading(false);
    }
  }, []);

  const clearError = useCallback(() => {
    setError(null);
  }, []);

  return (
    <div className="topup-form">
      {error && (
        <ErrorDisplay 
          error={error} 
          onRetry={() => handleCreateTopup(amount, selectedAccount)}
          onDismiss={clearError}
        />
      )}
      
      {/* Rest of component */}
    </div>
  );
};
```

