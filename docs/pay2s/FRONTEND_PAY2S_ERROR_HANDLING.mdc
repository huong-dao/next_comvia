## 4. Specific Error Scenarios

### 4.1 Amount Validation Errors
```typescript
// src/utils/amountValidation.ts
export const validateTopupAmount = (amount: number): TopupError | null => {
  const MIN_AMOUNT = 10000;
  const MAX_AMOUNT = 100000000; // 100 triệu

  if (isNaN(amount) || amount <= 0) {
    return new TopupError(TopupErrorCode.INVALID_AMOUNT, 'Amount must be a positive number');
  }

  if (amount < MIN_AMOUNT) {
    return new TopupError(TopupErrorCode.AMOUNT_TOO_SMALL, `Amount must be at least ${MIN_AMOUNT.toLocaleString()} VNĐ`);
  }

  if (amount > MAX_AMOUNT) {
    return new TopupError(TopupErrorCode.AMOUNT_TOO_LARGE, `Amount cannot exceed ${MAX_AMOUNT.toLocaleString()} VNĐ`);
  }

  return null;
};

// Usage in component
const handleAmountChange = (value: string) => {
  const amount = Number(value);
  const validationError = validateTopupAmount(amount);
  
  if (validationError) {
    setError(validationError);
    setAmount(null);
  } else {
    setError(null);
    setAmount(amount);
  }
};
```

### 4.2 Money Account Validation
```typescript
// src/utils/moneyAccountValidation.ts
export const validateMoneyAccount = (account: MoneyAccount | null): TopupError | null => {
  if (!account) {
    return new TopupError(TopupErrorCode.NO_MONEY_ACCOUNT, 'No money account selected');
  }

  if (!account.isActive) {
    return new TopupError(TopupErrorCode.INVALID_MONEY_ACCOUNT, 'Selected money account is inactive');
  }

  if (!account.pay2sBankId) {
    return new TopupError(TopupErrorCode.INVALID_MONEY_ACCOUNT, 'Money account not configured for Pay2S');
  }

  return null;
};
```

### 4.3 Payment Timeout Handling
```typescript
// src/components/PaymentMonitor.tsx
const PaymentMonitor: React.FC<{ collectionRequestCode: string }> = ({ collectionRequestCode }) => {
  const [status, setStatus] = useState<'pending' | 'paid' | 'failed' | 'expired'>('pending');
  const [timeLeft, setTimeLeft] = useState(5 * 60); // 5 minutes

  useEffect(() => {
    const startTime = Date.now();
    const timeoutDuration = 5 * 60 * 1000; // 5 minutes

    const interval = setInterval(async () => {
      const elapsed = Date.now() - startTime;
      const remaining = Math.max(0, timeoutDuration - elapsed);
      setTimeLeft(Math.ceil(remaining / 1000));

      if (remaining <= 0) {
        setStatus('expired');
        clearInterval(interval);
        return;
      }

      try {
        const collectionRequest = await getCollectionRequest(collectionRequestCode);
        
        if (collectionRequest.status === 'PAID') {
          setStatus('paid');
          clearInterval(interval);
        } else if (collectionRequest.status === 'FAILED') {
          setStatus('failed');
          clearInterval(interval);
        }
      } catch (error) {
        console.error('Status check failed:', error);
      }
    }, 3000);

    return () => clearInterval(interval);
  }, [collectionRequestCode]);

  if (status === 'expired') {
    return (
      <ErrorDisplay
        error={new TopupError(TopupErrorCode.PAYMENT_EXPIRED, 'Payment QR code expired')}
        onRetry={() => window.location.reload()}
      />
    );
  }

  return (
    <div className="payment-monitor">
      <div className="status-indicator">
        <div className="spinner"></div>
        <p>Đang chờ thanh toán...</p>
      </div>
      <div className="countdown">
        <p>Thời gian còn lại: {Math.floor(timeLeft / 60)}:{(timeLeft % 60).toString().padStart(2, '0')}</p>
      </div>
    </div>
  );
};
```

## 5. Retry Logic Implementation

### 5.1 Exponential Backoff Retry
```typescript
// src/utils/retry.ts
export const retryWithBackoff = async <T>(
  fn: () => Promise<T>,
  maxRetries: number = 3,
  baseDelay: number = 1000
): Promise<T> => {
  let lastError: any;

  for (let i = 0; i < maxRetries; i++) {
    try {
      return await fn();
    } catch (error) {
      lastError = error;

      // Don't retry on certain errors
      if (error instanceof TopupError && 
          (error.errorCode === TopupErrorCode.INVALID_AMOUNT ||
           error.errorCode === TopupErrorCode.NO_MONEY_ACCOUNT)) {
        throw error;
      }

      if (i === maxRetries - 1) {
        throw error;
      }

      // Calculate delay with exponential backoff
      const delay = baseDelay * Math.pow(2, i) + Math.random() * 1000;
      await new Promise(resolve => setTimeout(resolve, delay));
    }
  }

  throw lastError;
};

// Usage
const createTopupWithRetry = (data: CreateTopupRequest) => {
  return retryWithBackoff(() => createTopupWithPay2S(data), 3, 1000);
};
```

### 5.2 Smart Retry Component
```typescript
// src/components/SmartRetry.tsx
interface SmartRetryProps {
  onRetry: () => Promise<void>;
  error: BaseError;
  maxRetries?: number;
}

const SmartRetry: React.FC<SmartRetryProps> = ({ onRetry, error, maxRetries = 3 }) => {
  const [retryCount, setRetryCount] = useState(0);
  const [isRetrying, setIsRetrying] = useState(false);

  const handleRetry = async () => {
    if (retryCount >= maxRetries) {
      return;
    }

    setIsRetrying(true);
    try {
      await onRetry();
      setRetryCount(0); // Reset on success
    } catch (err) {
      setRetryCount(prev => prev + 1);
    } finally {
      setIsRetrying(false);
    }
  };

  if (retryCount >= maxRetries) {
    return (
      <div className="max-retries-reached">
        <p>Đã thử lại {maxRetries} lần nhưng không thành công.</p>
        <button onClick={() => window.location.reload()}>
          Tải lại trang
        </button>
      </div>
    );
  }

  return (
    <button 
      className="retry-button" 
      onClick={handleRetry}
      disabled={isRetrying}
    >
      {isRetrying ? 'Đang thử lại...' : `Thử lại (${maxRetries - retryCount} lần còn lại)`}
    </button>
  );
};
```

## 6. Error Analytics and Logging

### 6.1 Error Tracking
```typescript
// src/utils/errorTracking.ts
export const trackError = (event: string, errorCode: string, details?: any) => {
  // Google Analytics
  window.gtag?.('event', 'error', {
    event_category: 'topup_flow',
    event_label: errorCode,
    custom_parameter_1: event,
    custom_parameter_2: JSON.stringify(details)
  });

  // Custom analytics
  if (window.analytics) {
    window.analytics.track('Error Occurred', {
      event,
      errorCode,
      details,
      timestamp: new Date().toISOString(),
      userAgent: navigator.userAgent,
      url: window.location.href
    });
  }

  // Console logging for development
  if (process.env.NODE_ENV === 'development') {
    console.group(`🚨 Error: ${event}`);
    console.error('Error Code:', errorCode);
    console.error('Details:', details);
    console.groupEnd();
  }
};

// Error boundary for React components
export class ErrorBoundary extends React.Component<
  { children: React.ReactNode },
  { hasError: boolean; error: Error | null }
> {
  constructor(props: any) {
    super(props);
    this.state = { hasError: false, error: null };
  }

  static getDerivedStateFromError(error: Error) {
    return { hasError: true, error };
  }

  componentDidCatch(error: Error, errorInfo: React.ErrorInfo) {
    trackError('react_error_boundary', error.name, {
      error: error.message,
      stack: error.stack,
      componentStack: errorInfo.componentStack
    });
  }

  render() {
    if (this.state.hasError) {
      return (
        <div className="error-fallback">
          <h2>Đã xảy ra lỗi không mong muốn</h2>
          <p>Vui lòng tải lại trang và thử lại.</p>
          <button onClick={() => window.location.reload()}>
            Tải lại trang
          </button>
        </div>
      );
    }

    return this.props.children;
  }
}
```

### 6.2 Performance Monitoring
```typescript
// src/utils/performanceMonitoring.ts
export const measureAPICall = async <T>(
  apiCall: () => Promise<T>,
  apiName: string
): Promise<T> => {
  const startTime = performance.now();
  
  try {
    const result = await apiCall();
    const duration = performance.now() - startTime;
    
    // Track successful API calls
    trackError('api_call_success', apiName, {
      duration: Math.round(duration),
      success: true
    });
    
    // Alert on slow responses
    if (duration > 5000) {
      console.warn(`Slow API call: ${apiName} took ${duration}ms`);
    }
    
    return result;
  } catch (error) {
    const duration = performance.now() - startTime;
    
    // Track failed API calls
    trackError('api_call_failed', apiName, {
      duration: Math.round(duration),
      success: false,
      error: error.message
    });
    
    throw error;
  }
};

// Usage
const topupWithMonitoring = (data: CreateTopupRequest) => {
  return measureAPICall(() => createTopupWithPay2S(data), 'create_topup');
};
```

