### 4.2 Payment Status Indicator
```typescript
// src/components/PaymentStatus.tsx
interface PaymentStatusProps {
  status: 'pending' | 'paid' | 'failed' | 'expired';
  message?: string;
}

const PaymentStatus: React.FC<PaymentStatusProps> = ({ status, message }) => {
  const getStatusConfig = () => {
    switch (status) {
      case 'pending':
        return {
          icon: '⏳',
          color: '#ff9500',
          title: 'Đang chờ thanh toán',
          description: message || 'Vui lòng quét mã QR để thanh toán'
        };
      case 'paid':
        return {
          icon: '✅',
          color: '#34c759',
          title: 'Thanh toán thành công',
          description: message || 'Thanh toán đã được xác nhận'
        };
      case 'failed':
        return {
          icon: '❌',
          color: '#ff3b30',
          title: 'Thanh toán thất bại',
          description: message || 'Thanh toán không thành công'
        };
      case 'expired':
        return {
          icon: '⏰',
          color: '#8e8e93',
          title: 'Hết hạn',
          description: message || 'QR code đã hết hạn'
        };
      default:
        return {
          icon: '❓',
          color: '#8e8e93',
          title: 'Không xác định',
          description: 'Trạng thái không xác định'
        };
    }
  };

  const config = getStatusConfig();

  return (
    <div className="payment-status" style={{ color: config.color }}>
      <div className="status-icon">{config.icon}</div>
      <div className="status-content">
        <h4>{config.title}</h4>
        <p>{config.description}</p>
      </div>
    </div>
  );
};

export default PaymentStatus;
```

