## 4. Error Handling Updates

### 4.1 New Error Types

#### Before (Mock Errors)
```typescript
const errors = {
  INVALID_AMOUNT: 'Amount must be positive',
  NETWORK_ERROR: 'Network error occurred',
  TIMEOUT: 'Request timeout'
};
```

#### After (Real Errors)
```typescript
const errors = {
  INVALID_AMOUNT: 'Amount must be at least 10,000 VND',
  NO_MONEY_ACCOUNT: 'No money account found',
  PAY2S_ERROR: 'Pay2S API error',
  INVALID_BILLING_INFO: 'Invalid billing information',
  PAYMENT_EXPIRED: 'Payment QR expired',
  PAYMENT_FAILED: 'Payment failed',
  NETWORK_ERROR: 'Network error occurred',
  TIMEOUT: 'Request timeout'
};

export const handleTopupError = (error: any): string => {
  if (error.response?.status === 400) {
    return errors.INVALID_AMOUNT;
  } else if (error.response?.status === 404) {
    return errors.NO_MONEY_ACCOUNT;
  } else if (error.response?.status === 502) {
    return errors.PAY2S_ERROR;
  } else {
    return errors.NETWORK_ERROR;
  }
};
```

### 4.2 Retry Logic

#### Before (Mock)
```typescript
// No retry needed for mock
```

#### After (Real)
```typescript
export const createTopupWithRetry = async (
  data: CreateTopupRequest,
  maxRetries = 3
): Promise<TopupRequest> => {
  for (let i = 0; i < maxRetries; i++) {
    try {
      return await createTopupWithPay2S(data);
    } catch (error) {
      if (i === maxRetries - 1) throw error;
      
      // Wait before retry
      await new Promise(resolve => setTimeout(resolve, 1000 * (i + 1)));
    }
  }
  
  throw new Error('Max retries exceeded');
};
```

## 5. Testing Migration

### 5.1 Unit Tests

#### Before (Mock Tests)
```typescript
describe('Mock Topup', () => {
  test('should create mock topup', async () => {
    const result = await createMockTopup(1100000, 'workspace_id');
    expect(result.qrCode).toBeTruthy();
    expect(result.amount).toBe(1100000);
  });
});
```

#### After (Real Tests)
```typescript
describe('Real Topup', () => {
  test('should create topup with Pay2S', async () => {
    const result = await createTopupWithPay2S({
      amountExclVat: 1000000,
      moneyAccountId: 'account_id'
    });
    
    expect(result.qrContent).toBeTruthy();
    expect(result.amountExclVat).toBe(1000000);
    expect(result.vatAmount).toBe(100000);
    expect(result.amountInclVat).toBe(1100000);
    expect(result.collectionRequestCode).toBeTruthy();
  });

  test('should handle insufficient amount', async () => {
    await expect(
      createTopupWithPay2S({ amountExclVat: 5000, moneyAccountId: 'account_id' })
    ).rejects.toThrow('Amount must be at least 10,000 VND');
  });
});
```

### 5.2 Integration Tests

```typescript
describe('Topup Flow Integration', () => {
  test('should complete full topup flow', async () => {
    // 1. Get money accounts
    const accounts = await getMoneyAccounts(workspaceId);
    expect(accounts.data.length).toBeGreaterThan(0);

