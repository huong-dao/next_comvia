## 3. Code Migration Steps

### 3.1 Update API Service

#### Before (Mock API Service)
```typescript
// src/services/mockTopupService.ts
export const createMockTopup = async (amount: number, workspaceId: string) => {
  const response = await fetch('/api/v1/topups/create-mock-qr', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ amount, workspaceId })
  });
  
  return response.json();
};

export const checkMockStatus = async (code: string) => {
  const response = await fetch(`/api/v1/topups/${code}/mock-status`);
  return response.json();
};
```

#### After (Real API Service)
```typescript
// src/services/topupService.ts
export interface CreateTopupRequest {
  amountExclVat: number;
  moneyAccountId: string;
}

export const createTopupWithPay2S = async (data: CreateTopupRequest) => {
  const response = await fetchWithAuth('/api/v1/topups/create-with-pay2s', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  });
  
  return response.json();
};

export const getTopupStatus = async (topupCode: string) => {
  const response = await fetchWithAuth(`/api/v1/topups/${topupCode}/status`);
  return response.json();
};

export const getCollectionRequest = async (code: string) => {
  const response = await fetchWithAuth(`/api/v1/collection-requests/code/${code}`);
  return response.json();
};
```

### 3.2 Update Component Logic

#### Before (Mock Component)
```typescript
const handleTopup = async (amount: number) => {
  try {
    const result = await createMockTopup(amount, workspaceId);
    setQrCode(result.qrCode);
    setTopupCode(result.topupCode);
    
    // Start polling mock status
    startStatusPolling(result.topupCode);
  } catch (error) {
    setError('Failed to create topup');
  }
};

const startStatusPolling = (code: string) => {
  const interval = setInterval(async () => {
    const status = await checkMockStatus(code);
    if (status.status === 'PAID') {
      handleSuccess();
      clearInterval(interval);
    }
  }, 3000);
};
```

#### After (Real Component)
```typescript
const handleTopup = async (amount: number, moneyAccountId: string) => {
  try {
    // Calculate amount before VAT
    const amountExclVat = Math.round(amount / 1.1);
    
    const result = await createTopupWithPay2S({
      amountExclVat,
      moneyAccountId
    });
    
    setQrCode(result.qrContent);
    setTopupCode(result.topupCode);
    setCollectionRequestCode(result.collectionRequestCode);
    
    // Start polling real status
    startStatusPolling(result.collectionRequestCode);
  } catch (error) {
    setError(handleTopupError(error));
  }
};

const startStatusPolling = (collectionRequestCode: string) => {
  const interval = setInterval(async () => {
    try {
      const collectionRequest = await getCollectionRequest(collectionRequestCode);
      
      if (collectionRequest.status === 'PAID') {
        handleSuccess(collectionRequest);
        clearInterval(interval);
      } else if (collectionRequest.status === 'FAILED') {
        handleFailure();
        clearInterval(interval);
      }
    } catch (error) {
      console.error('Status check failed:', error);
    }
  }, 3000);
  
  // Set timeout for QR expiry
  setTimeout(() => {
    clearInterval(interval);
    handleExpiry();
  }, 5 * 60 * 1000); // 5 minutes
};
```

