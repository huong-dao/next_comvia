## 11. Common Issues and Solutions

### 11.1 Issue: QR Code Not Displaying
**Cause**: Invalid base64 data or wrong image format
**Solution**: 
```typescript
// Validate QR data
const isValidBase64 = (str: string) => {
  try {
    return btoa(atob(str)) === str;
  } catch (err) {
    return false;
  }
};

// Usage
if (isValidBase64(qrContent)) {
  // Display QR code
} else {
  // Show error message
}
```

### 11.2 Issue: Status Not Updating
**Cause**: Wrong polling endpoint or interval
**Solution**:
```typescript
// Use correct endpoint
const checkStatus = async (code: string) => {
  // Use collection request endpoint instead of topup status
  return await getCollectionRequest(code);
};

// Optimize polling interval
const POLLING_INTERVAL = 3000; // 3 seconds
const MAX_POLLING_TIME = 5 * 60 * 1000; // 5 minutes
```

### 11.3 Issue: Amount Calculation Error
**Cause**: Wrong VAT calculation
**Solution**:
```typescript
// Correct VAT calculation
const calculateAmounts = (totalAmount: number) => {
  const vatRate = 0.1;
  const amountExclVat = Math.round(totalAmount / (1 + vatRate));
  const vatAmount = totalAmount - amountExclVat;
  
  return { amountExclVat, vatAmount, totalAmount };
};
```

